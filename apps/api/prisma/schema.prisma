generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum EmployeeInvitationStatus {
  INVITED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum AttendanceEventType {
  CHECK_IN
  CHECK_OUT
  BREAK_START
  BREAK_END
}

enum AttendanceResult {
  ACCEPTED
  REJECTED
}

enum AttendanceSessionStatus {
  OPEN
  ON_BREAK
  CLOSED
}

enum BiometricEnrollmentStatus {
  NOT_STARTED
  PENDING
  ENROLLED
  FAILED
}

enum BiometricVerificationResult {
  PASSED
  FAILED
  REVIEW
}

enum BiometricArtifactKind {
  ENROLLMENT
  VERIFICATION
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum RequestType {
  LEAVE
  SICK_LEAVE
  VACATION_CHANGE
  UNPAID_LEAVE
  SHIFT_CHANGE
  ADVANCE
  SUPPLY
  GENERAL
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum NotificationType {
  REQUEST_ACTION_REQUIRED
  REQUEST_APPROVED
  REQUEST_REJECTED
  EMPLOYEE_APPROVAL_ACTION_REQUIRED
  EMPLOYEE_APPROVED
  EMPLOYEE_REJECTED
  BIOMETRIC_REVIEW_ACTION_REQUIRED
  BIOMETRIC_REVIEW_APPROVED
  BIOMETRIC_REVIEW_REJECTED
  ATTENDANCE_CORRECTION_ACTION_REQUIRED
  ATTENDANCE_CORRECTION_APPROVED
  ATTENDANCE_CORRECTION_REJECTED
  ATTENDANCE_ANOMALY_CRITICAL
  OPERATIONS_ALERT
  DAILY_DIGEST
}

enum BiometricManualReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PushProvider {
  EXPO
}

enum AttendanceCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeOffBalanceKind {
  VACATION
  PERSONAL_DAY_OFF
}

enum TimeOffTransactionType {
  SET
  ADJUST
  ACCRUAL
  RESERVED
  RELEASED
  CONSUMED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskTemplateFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum AnnouncementTemplateFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskActivityKind {
  CREATED
  COMMENT
  STATUS_CHANGED
  CHECKLIST_TOGGLED
}

enum AnnouncementAudience {
  ALL
  GROUP
  EMPLOYEE
  DEPARTMENT
  LOCATION
}

enum ChatThreadKind {
  DIRECT
  GROUP
}

enum ExportJobType {
  ATTENDANCE_HISTORY
  PAYROLL_SUMMARY
}

enum ExportJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum PushDeliveryStatus {
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
}

enum PushReceiptStatus {
  PENDING
  OK
  ERROR
}

enum BiometricJobType {
  VERIFY
}

enum BiometricJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Tenant {
  id                 String               @id @default(uuid())
  /// Internal business identifier for billing and integration checks. Keep out of user-facing DTOs.
  businessId         String               @unique @default(uuid())
  name               String
  slug               String               @unique
  timezone           String               @default("UTC")
  locale             String               @default("en")
  hideLeaderboardPeersFromEmployees Boolean @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  users              User[]
  companies          Company[]
  departments        Department[]
  locations          Location[]
  positions          Position[]
  employees          Employee[]
  employeeInvitations EmployeeInvitation[]
  attendanceEvents   AttendanceEvent[]
  attendanceSessions AttendanceSession[]
  attendanceBreaks   AttendanceBreak[]
  auditLogs          AuditLog[]
  shiftTemplates     ShiftTemplate[]
  shifts             Shift[]
  requests           EmployeeRequest[]
  requestComments    RequestComment[]
  approvalSteps      RequestApprovalStep[]
  approvalPolicies   ApprovalPolicy[]
  payrollPolicy      PayrollPolicy?
  holidayCalendarDays HolidayCalendarDay[]
  notifications      Notification[]
  timeOffBalances    EmployeeTimeOffBalance[]
  timeOffTransactions EmployeeTimeOffTransaction[]
  workGroups         WorkGroup[]
  workGroupMembers   WorkGroupMembership[]
  tasks              Task[]
  taskTemplates      TaskTemplate[]
  taskCompletions    TaskCompletion[]
  taskPhotoProofs    TaskPhotoProof[]
  announcementTemplates AnnouncementTemplate[]
  checklistItems     TaskChecklistItem[]
  taskActivities     TaskActivity[]
  announcements      Announcement[]
  chatThreads        ChatThread[]
  chatParticipants   ChatParticipant[]
  chatMessages       ChatMessage[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]
  anomalyNotifications AttendanceAnomalyNotification[]
  attendanceCorrectionComments AttendanceCorrectionComment[]
  pushDevices        PushDevice[]
  pushDeliveries     PushDelivery[]
  biometricArtifacts BiometricArtifact[]
  biometricJobs      BiometricJob[]
  exportJobs         ExportJob[]
  requestAttachments RequestAttachment[]
  diagnosticsPolicy  DiagnosticsPolicy?
  taskAutomationPolicy TaskAutomationPolicy?
  diagnosticsSnapshots DiagnosticsSnapshot[]
  billingSubscription BillingSubscription?
}

model BillingSubscription {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  paidSeats Int      @default(1)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DiagnosticsPolicy {
  id                                 String   @id @default(uuid())
  tenantId                           String   @unique
  exportQueueWarningMinutes          Int      @default(10)
  exportQueueCriticalMinutes         Int      @default(20)
  biometricQueueWarningMinutes       Int      @default(10)
  biometricQueueCriticalMinutes      Int      @default(20)
  exportFailureWarningCount24h       Int      @default(1)
  biometricFailureWarningCount24h    Int      @default(1)
  pushFailureCriticalCount24h        Int      @default(1)
  pushReceiptErrorCriticalCount      Int      @default(1)
  criticalAnomaliesCriticalCount     Int      @default(1)
  pendingBiometricReviewWarningCount Int      @default(1)
  repeatIntervalMinutes              Int      @default(60)
  notifyTenantOwner                  Boolean  @default(true)
  notifyHrAdmin                      Boolean  @default(true)
  notifyOperationsAdmin              Boolean  @default(true)
  notifyManagers                     Boolean  @default(false)
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TaskAutomationPolicy {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  reminderLeadDays    Int      @default(2)
  reminderRepeatHours Int      @default(24)
  escalationDelayDays Int      @default(1)
  escalateToManager   Boolean  @default(true)
  notifyAssignee      Boolean  @default(true)
  sendChatMessages    Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DiagnosticsSnapshot {
  id                           String   @id @default(uuid())
  tenantId                     String
  exportQueued                 Int      @default(0)
  exportProcessing             Int      @default(0)
  exportFailed                 Int      @default(0)
  exportCompleted              Int      @default(0)
  exportOldestQueuedMinutes    Int      @default(0)
  biometricQueued              Int      @default(0)
  biometricProcessing          Int      @default(0)
  biometricFailed              Int      @default(0)
  biometricCompleted           Int      @default(0)
  biometricOldestQueuedMinutes Int      @default(0)
  pushQueued                   Int      @default(0)
  pushProcessing               Int      @default(0)
  pushFailed                   Int      @default(0)
  pushDelivered                Int      @default(0)
  pushPendingReceipts          Int      @default(0)
  pushReceiptErrors            Int      @default(0)
  criticalAnomaliesToday       Int      @default(0)
  pendingBiometricReviews      Int      @default(0)
  exportFailures24h            Int      @default(0)
  biometricFailures24h         Int      @default(0)
  pushFailures24h              Int      @default(0)
  criticalAlerts               Int      @default(0)
  warningAlerts                Int      @default(0)
  capturedAt                   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, capturedAt])
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  status       UserStatus @default(INVITED)
  workspaceAccessAllowed Boolean @default(true)
  bannerTheme  String     @default("blue")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles    UserRole[]
  employee Employee?
  sessions Session[]
  notifications Notification[]
  pushDevices PushDevice[]
  pushDeliveries PushDelivery[]
  exportJobs ExportJob[]
  sentEmployeeInvitations EmployeeInvitation[] @relation("EmployeeInvitationSender")
  registeredEmployeeInvitations EmployeeInvitation[] @relation("EmployeeInvitationRegistrant")
  approvedEmployeeInvitations EmployeeInvitation[] @relation("EmployeeInvitationApprover")

  @@unique([tenantId, email])
}

model Role {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  users       UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  scopeType String
  scopeId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  logoUrl   String?
  googlePlaceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  locations Location[]
  employeeInvitations EmployeeInvitation[]

  @@unique([tenantId, name])
}

model Department {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  code               String
  parentDepartmentId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees        Employee[]
  approvalPolicies ApprovalPolicy[]
  taskTemplates    TaskTemplate[]
  announcementTemplates AnnouncementTemplate[]
  announcements    Announcement[]

  @@unique([tenantId, code])
}

model Location {
  id                   String   @id @default(uuid())
  tenantId             String
  companyId            String
  name                 String
  code                 String
  address              String
  country              String?
  latitude             Float
  longitude            Float
  geofenceRadiusMeters Int      @default(100)
  timezone             String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees          Employee[]
  attendanceEvents   AttendanceEvent[]
  shiftTemplates     ShiftTemplate[]
  shifts             Shift[]
  approvalPolicies   ApprovalPolicy[]
  taskTemplates      TaskTemplate[]
  announcementTemplates AnnouncementTemplate[]
  announcements      Announcement[]

  @@unique([tenantId, code])
}

model Position {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  shiftTemplates ShiftTemplate[]
  shifts     Shift[]

  @@unique([tenantId, code])
}

model Employee {
  id                  String                  @id @default(uuid())
  tenantId            String
  userId              String                  @unique
  companyId           String
  departmentId        String
  primaryLocationId   String
  positionId          String
  managerEmployeeId   String?
  employeeNumber      String
  firstName           String
  lastName            String
  middleName          String?
  birthDate           DateTime?
  gender              String?
  phone               String?
  avatarStorageKey    String?
  avatarUrl           String?
  breaksEnabled       Boolean                 @default(false)
  status              EmployeeStatus          @default(ACTIVE)
  hireDate            DateTime
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department          Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  primaryLocation     Location                @relation(fields: [primaryLocationId], references: [id], onDelete: Cascade)
  position            Position                @relation(fields: [positionId], references: [id], onDelete: Cascade)
  devices             Device[]
  attendanceEvents    AttendanceEvent[]
  attendanceSessions  AttendanceSession[]
  attendanceBreaks    AttendanceBreak[]
  biometricProfile    BiometricProfile?
  biometricChecks     BiometricVerification[]
  reviewedBiometricChecks BiometricVerification[] @relation("BiometricVerificationReviewer")
  biometricArtifacts  BiometricArtifact[]
  biometricJobs       BiometricJob[]
  shifts              Shift[]
  submittedRequests   EmployeeRequest[]          @relation("RequestSubmitter")
  approvalsToAct      RequestApprovalStep[]      @relation("ApprovalActor")
  managedRequests     EmployeeRequest[]          @relation("RequestManager")
  approvalPolicies    ApprovalPolicy[]           @relation("PolicyApprover")
  requestComments     RequestComment[]           @relation("RequestCommentAuthor")
  timeOffBalances     EmployeeTimeOffBalance[]
  timeOffTransactions EmployeeTimeOffTransaction[]
  requestAttachments  RequestAttachment[]        @relation("RequestAttachmentUploader")
  ownedGroups         WorkGroup[]                @relation("WorkGroupManager")
  groupMemberships    WorkGroupMembership[]
  createdTasks        Task[]                     @relation("TaskManager")
  createdTaskTemplates TaskTemplate[]            @relation("TaskTemplateManager")
  assignedTaskTemplates TaskTemplate[]           @relation("TaskTemplateAssignee")
  assignedTasks       Task[]                     @relation("TaskAssignee")
  taskCompletions     TaskCompletion[]
  uploadedTaskPhotoProofs TaskPhotoProof[]    @relation("TaskPhotoProofUploader")
  completedChecklistItems TaskChecklistItem[]    @relation("ChecklistCompletedBy")
  taskActivities      TaskActivity[]
  createdAnnouncements Announcement[]            @relation("AnnouncementAuthor")
  targetedAnnouncements Announcement[]           @relation("AnnouncementTargetEmployee")
  announcementEmployeeTargets AnnouncementEmployeeTarget[]
  createdAnnouncementTemplates AnnouncementTemplate[] @relation("AnnouncementTemplateManager")
  targetedAnnouncementTemplates AnnouncementTemplate[] @relation("AnnouncementTemplateTargetEmployee")
  createdChatThreads  ChatThread[]               @relation("ChatThreadCreator")
  chatParticipants    ChatParticipant[]
  chatMessages        ChatMessage[]
  submittedAttendanceCorrections AttendanceCorrectionRequest[] @relation("AttendanceCorrectionRequester")
  attendanceCorrectionsToApprove AttendanceCorrectionRequest[] @relation("AttendanceCorrectionApprover")
  attendanceCorrectionsForEmployee AttendanceCorrectionRequest[] @relation("AttendanceCorrectionEmployee")
  attendanceCorrectionComments AttendanceCorrectionComment[] @relation("AttendanceCorrectionCommentAuthor")
  invitation          EmployeeInvitation?

  @@unique([tenantId, employeeNumber])
}

model EmployeeInvitation {
  id               String                   @id @default(uuid())
  tenantId         String
  companyId        String?
  email            String?
  invitedByUserId  String
  userId           String?                  @unique
  approvedByUserId String?
  employeeId       String?                  @unique
  approvedShiftTemplateId String?
  approvedGroupId  String?
  status           EmployeeInvitationStatus @default(INVITED)
  tokenHash        String                   @unique
  expiresAt        DateTime
  invitedAt        DateTime                 @default(now())
  lastSentAt       DateTime                 @default(now())
  resentCount      Int                      @default(0)
  submittedAt      DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  firstName        String?
  lastName         String?
  middleName       String?
  birthDate        DateTime?
  gender           String?
  phone            String?
  avatarStorageKey String?
  avatarUrl        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company          Company?                 @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invitedByUser    User                     @relation("EmployeeInvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  user             User?                    @relation("EmployeeInvitationRegistrant", fields: [userId], references: [id], onDelete: SetNull)
  approvedByUser   User?                    @relation("EmployeeInvitationApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  employee         Employee?                @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  approvedShiftTemplate ShiftTemplate?      @relation(fields: [approvedShiftTemplateId], references: [id], onDelete: SetNull)
  approvedGroup    WorkGroup?               @relation(fields: [approvedGroupId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, status, invitedAt])
}

model EmployeeTimeOffBalance {
  id            String              @id @default(uuid())
  tenantId      String
  employeeId    String
  kind          TimeOffBalanceKind
  allowanceDays Float               @default(0)
  usedDays      Float               @default(0)
  pendingDays   Float               @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  transactions  EmployeeTimeOffTransaction[]

  @@unique([employeeId, kind])
  @@index([tenantId, kind, updatedAt])
}

model EmployeeTimeOffTransaction {
  id                         String                 @id @default(uuid())
  tenantId                   String
  employeeId                 String
  balanceId                  String
  kind                       TimeOffBalanceKind
  type                       TimeOffTransactionType
  deltaDays                  Float
  balanceAfterAllowanceDays  Float
  balanceAfterUsedDays       Float
  balanceAfterPendingDays    Float
  note                       String?
  requestId                  String?
  actorUserId                String?
  createdAt                  DateTime               @default(now())

  tenant                     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee                   Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  balance                    EmployeeTimeOffBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  request                    EmployeeRequest?       @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId, kind, createdAt])
  @@index([tenantId, requestId])
}

model Device {
  id                String             @id @default(uuid())
  employeeId        String
  platform          DevicePlatform
  deviceFingerprint String
  deviceName        String?
  isPrimary         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  employee          Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceEvents  AttendanceEvent[]

  @@unique([employeeId, deviceFingerprint])
}

model ShiftTemplate {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  code               String
  locationId         String
  positionId         String
  startsAtLocal      String
  endsAtLocal        String
  weekDaysJson       String?
  gracePeriodMinutes Int      @default(10)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  shifts   Shift[]
  approvedInvitations EmployeeInvitation[]

  @@unique([tenantId, code])
}

model Shift {
  id          String      @id @default(uuid())
  tenantId    String
  templateId  String
  employeeId  String
  locationId  String
  positionId  String
  shiftDate   DateTime
  startsAt    DateTime
  endsAt      DateTime
  status      ShiftStatus @default(PUBLISHED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  position Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attendanceSessions AttendanceSession[]

  @@index([tenantId, employeeId, shiftDate])
}

model AttendanceEvent {
  id               String              @id @default(uuid())
  tenantId         String
  employeeId       String
  eventType        AttendanceEventType
  result           AttendanceResult    @default(ACCEPTED)
  occurredAt       DateTime
  serverRecordedAt DateTime            @default(now())
  latitude         Float
  longitude        Float
  accuracyMeters   Float
  distanceMeters   Float
  notes            String?
  locationId       String
  deviceId         String
  createdAt        DateTime            @default(now())

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee         Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location         Location                 @relation(fields: [locationId], references: [id], onDelete: Cascade)
  device           Device                   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  biometricChecks  BiometricVerification[]

  openedSession AttendanceSession? @relation("SessionCheckIn")
  closedSession AttendanceSession? @relation("SessionCheckOut")
  startedBreaks AttendanceBreak[] @relation("BreakStartEvent")
  endedBreaks   AttendanceBreak[] @relation("BreakEndEvent")

  @@index([tenantId, employeeId, occurredAt])
}

model AttendanceSession {
  id                String                  @id @default(uuid())
  tenantId          String
  employeeId        String
  shiftId           String?
  checkInEventId    String                  @unique
  checkOutEventId   String?                 @unique
  status            AttendanceSessionStatus @default(OPEN)
  startedAt         DateTime
  endedAt           DateTime?
  totalMinutes      Int                     @default(0)
  lateMinutes       Int                     @default(0)
  earlyLeaveMinutes Int                     @default(0)
  breakMinutes      Int                     @default(0)
  paidBreakMinutes  Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id])
  checkInEvent  AttendanceEvent @relation("SessionCheckIn", fields: [checkInEventId], references: [id], onDelete: Cascade)
  checkOutEvent AttendanceEvent? @relation("SessionCheckOut", fields: [checkOutEventId], references: [id])
  breaks     AttendanceBreak[]
  correctionRequests AttendanceCorrectionRequest[]

  @@index([tenantId, employeeId, startedAt])
}

model AttendanceBreak {
  id            String   @id @default(uuid())
  tenantId      String
  employeeId    String
  sessionId     String
  startEventId  String   @unique
  endEventId    String?  @unique
  isPaid        Boolean  @default(false)
  startedAt     DateTime
  endedAt       DateTime?
  totalMinutes  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  startEvent  AttendanceEvent   @relation("BreakStartEvent", fields: [startEventId], references: [id], onDelete: Cascade)
  endEvent    AttendanceEvent?  @relation("BreakEndEvent", fields: [endEventId], references: [id])

  @@index([tenantId, employeeId, startedAt])
  @@index([tenantId, sessionId, startedAt])
}

model AttendanceCorrectionRequest {
  id                  String                     @id @default(uuid())
  tenantId            String
  sessionId           String
  employeeId          String
  requestedByEmployeeId String
