  tenantId       String
  employeeId     String
  type           BiometricJobType
  status         BiometricJobStatus @default(QUEUED)
  payloadJson    String?
  resultJson     String?
  errorMessage   String?
  attempts       Int                @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, type, status, createdAt])
}

model ExportJob {
  id                String          @id @default(uuid())
  tenantId          String
  requestedByUserId String
  type              ExportJobType
  format            String
  status            ExportJobStatus @default(QUEUED)
  parametersJson    String?
  storageKey        String?
  fileName          String?
  contentType       String?
  errorMessage      String?
  attempts          Int             @default(0)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUser   User            @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, status, createdAt])
  @@index([requestedByUserId, createdAt])
}
